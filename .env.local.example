NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sua-chave-publica-aqui

# Links publicos de checkout usados na tela /planos.
# Deixe vazio enquanto ainda nao houver checkout publicado.
NEXT_PUBLIC_PERFECTPAY_MONTHLY_CHECKOUT_URL=
NEXT_PUBLIC_PERFECTPAY_ANNUAL_CHECKOUT_URL=

# Secrets da Edge Function perfectpay-webhook.
# Configure estes valores no Supabase Dashboard > Edge Functions > Secrets.
PERFECTPAY_MONTHLY_PLAN_CODE=
PERFECTPAY_ANNUAL_PLAN_CODE=
PERFECTPAY_PRODUCT_CODE=
PERFECTPAY_WEBHOOK_TOKEN=
APP_URL=https://seu-dominio.com
SUPABASE_SERVICE_ROLE_KEY=

# Legado: mantenha apenas se ainda estiver operando checkout Kirvano em paralelo.
NEXT_PUBLIC_KIRVANO_PRO_CHECKOUT_URL=
NEXT_PUBLIC_KIRVANO_BUSINESS_CHECKOUT_URL=

# Sem essas variaveis preenchidas, o app roda em modo local usando localStorage.
